{
  "global_settings": {
    "type": "object",
    "description": "⚙️ 全局核心设置",
    "items": {
      "prefix": {
        "type": "string",
        "description": "唤醒前缀",
        "default": "/luck",
        "hint": "所有金币系统指令的固定前缀，强烈建议保留斜杠以防与机器人的日常对话冲突。"
      }
    }
  },
  "admin_settings": {
    "type": "object",
    "description": "👑 天道权限 (管理员设定)",
    "items": {
      "use_native_admin": {
        "type": "bool",
        "description": "挂钩 AstrBot 原生管理员",
        "default": true,
        "hint": "开启后，系统会自动识别 AstrBot 原生配置中的 Bot 管理员，为其赋予特权命令。"
      },
      "extra_admin_qqs": {
        "type": "string",
        "description": "额外管理员 QQ",
        "default": "",
        "hint": "除原生管理员外，额外赋予特权的人员。多个QQ号请用英文逗号(,)分隔。"
      }
    }
  },
  "ui_settings": {
    "type": "object",
    "description": "🖥️ 界面与显示设置",
    "items": {
      "panel_title": {
        "type": "string",
        "description": "个人面板顶部标题",
        "default": "【个人状态观测仪】",
        "hint": "自定义用户发送 /luck 面板 时，回复文本最顶部的展示标题。"
      },
      "board_length": {
        "type": "int",
        "description": "榜单展示长度",
        "default": 10,
        "hint": "排行榜显示前 N 名与倒数前 N 名。"
      }
    }
  },
  "webui_settings": {
    "type": "object",
    "description": "🌐 WebUI 管理界面",
    "items": {
      "enable": {
        "type": "bool",
        "description": "开启本地 WebUI",
        "default": false,
        "hint": "开启后会启动一个图形化管理页面。访问地址前半段取决于运行环境，后面的端口由下方配置项决定。"
      },
      "port": {
        "type": "int",
        "description": "WebUI 端口",
        "default": 4399,
        "hint": "默认端口为 4399，可按需修改为其他未占用端口。本地常见访问方式为 127.0.0.1:端口，服务器常见访问方式为 服务器地址:端口。"
      },
      "access_password": {
        "type": "string",
        "description": "WebUI 访问口令",
        "default": "12345678",
        "hint": "管理界面的进入口令。留空时也会自动回退到默认值 12345678。"
      }
    }
  },
  "sign_in_settings": {
    "type": "object",
    "description": "📜 基础运势观测 (签到)",
    "items": {
      "enable": {
        "type": "bool",
        "description": "开启基础运势",
        "default": true,
        "hint": "关闭后，用户将无法使用签到功能获取每日的基础运势波动。"
      }
    }
  },
  "fate_cards_settings": {
    "type": "object",
    "description": "🎴 命运牌系统 (每日抽换)",
    "items": {
      "enable": {
        "type": "bool",
        "description": "开启命运牌",
        "default": true,
        "hint": "关闭后，将停用依赖 cards_config.json 的传统图片命运牌抽卡与换牌功能。"
      },
      "daily_draw_limit": {
        "type": "int",
        "description": "每日换牌上限",
        "default": 3,
        "condition": {
          "enable": true
        },
        "hint": "玩家每天最多可以抽取或替换多少次命运牌（包含首次抽取）。"
      }
    }
  },
  "func_cards_settings": {
    "type": "object",
    "description": "⚔️ 战术功能牌 (干涉与博弈)",
    "items": {
      "enable": {
        "type": "bool",
        "description": "开启功能牌",
        "default": true,
        "hint": "关闭后，整个类似三国杀的战术博弈、卡槽系统将全部休眠。"
      },
      "enable_dice_cards": {
        "type": "bool",
        "description": "开启骰子玩法与骰子功能牌",
        "default": true,
        "condition": {
          "enable": true
        },
        "hint": "关闭后将过滤所有骰子类功能牌（如决斗/重投），已持有的骰子牌也无法正常触发。"
      },
      "enable_public_duel_mode": {
        "type": "bool",
        "description": "开启公开决斗模式",
        "default": false,
        "condition": {
          "enable": true
        },
        "hint": "开启后无需功能牌，玩家可直接发起带投入的公开决斗；必须双方明确确认才会开打。"
      },
      "public_duel_daily_limit": {
        "type": "int",
        "description": "公开决斗每日上限（每人）",
        "default": 3,
        "condition": {
          "enable": true,
          "enable_public_duel_mode": true
        },
        "hint": "公开决斗模式下，每位玩家每天最多可主动发起的次数。"
      },
      "public_duel_min_stake": {
        "type": "int",
        "description": "公开决斗最低投入",
        "default": 10,
        "condition": {
          "enable": true,
          "enable_public_duel_mode": true
        },
        "hint": "无需功能牌的公开决斗中，允许发起的最低金币投入。"
      },
      "public_duel_max_stake": {
        "type": "int",
        "description": "公开决斗最高投入",
        "default": 200,
        "condition": {
          "enable": true,
          "enable_public_duel_mode": true
        },
        "hint": "公开决斗与追加投入都不能超过该上限。"
      },
      "enable_rarity_dedup": {
        "type": "bool",
        "description": "开启同档去重",
        "default": true,
        "hint": "开启后，短期内重复抽到同一张牌的概率会被压低，优先把同稀有度内没出过的牌轮一遍。关闭后每张牌概率完全均等。"
      },
      "rarity_mode": {
        "type": "string",
        "description": "稀有度爆率模式",
        "default": "default",
        "hint": "default = 使用内置概率分布（普通30/稀有30/史诗28/传说11/神话1）；custom = 使用下方自定义权重值，各档权重之和无需为100，系统自动归一。"
      },
      "custom_rarity_weights": {
        "type": "object",
        "description": "⚙️ 自定义稀有度权重（rarity_mode 为 custom 时生效）",
        "condition": {
          "enable": true
        },
        "items": {
          "rarity_1": {
            "type": "int",
            "description": "普通(1) 权重",
            "default": 30,
            "hint": "权重越高出现概率越大，与其他档位的权重成比例计算。"
          },
          "rarity_2": {
            "type": "int",
            "description": "稀有(2) 权重",
            "default": 30,
            "hint": "权重越高出现概率越大，与其他档位的权重成比例计算。"
          },
          "rarity_3": {
            "type": "int",
            "description": "史诗(3) 权重",
            "default": 28,
            "hint": "权重越高出现概率越大，与其他档位的权重成比例计算。"
          },
          "rarity_4": {
            "type": "int",
            "description": "传说(4) 权重",
            "default": 11,
            "hint": "权重越高出现概率越大，与其他档位的权重成比例计算。"
          },
          "rarity_5": {
            "type": "int",
            "description": "神话(5) 权重",
            "default": 1,
            "hint": "权重越高出现概率越大，与其他档位的权重成比例计算。"
          }
        }
      },
      "max_equipped_titles": {
        "type": "int",
        "description": "最多可佩戴称号数",
        "default": 3,
        "condition": {
          "enable": true
        },
        "hint": "玩家可同时佩戴并生效的称号数量上限。超出的已拥有称号仍会保留，但不会生效。"
      },
      "economy_settings": {
        "type": "object",
        "description": "💰 抽取与经济参数",
        "condition": {
          "enable": true
        },
        "items": {
          "draw_probability": {
            "type": "int",
            "description": "功能牌基础掉率 (%)",
            "default": 5,
            "hint": "每次抽取获得功能牌的概率（百分比）。填写 5 即代表 5%。"
          },
          "free_daily_draw": {
            "type": "int",
            "description": "每日免费抽取次数",
            "default": 1,
            "hint": "每天赠送的抽取机会，深渊状态（负金币）也可白嫖此机会。"
          },
          "draw_cost": {
            "type": "int",
            "description": "单次抽取消耗 (金币)",
            "default": 20,
            "hint": "耗尽免费次数后，额外抽取功能牌所需扣除的金币值（不足不可抽）。"
          },
          "pity_threshold": {
            "type": "int",
            "description": "深渊保底阈值 (次数)",
            "default": 10,
            "hint": "连续未抽中功能牌的累计次数。达到此数值后，下次必定获得功能牌。"
          }
        }
      }
    }
  }
}
